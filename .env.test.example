# Integration test environment
# Copy this to .env.test and set your test database URL.
# The integration tests will use TEST_DATABASE_URL if set,
# otherwise they fall back to DATABASE_URL from .env.
#
# IMPORTANT: Use a SEPARATE database for tests.
# All tables are truncated after each test suite.

PORT=5001
NODE_ENV=test
JWT_SECRET=test_jwt_secret_for_integration_tests
JWT_EXPIRE=7d

# Point at a dedicated test database to avoid wiping real data
TEST_DATABASE_URL=postgresql://postgres:h0minh@localhost:5432/baorongvang_test
DATABASE_URL=postgresql://postgres:h0minh@localhost:5432/baorongvang_test
